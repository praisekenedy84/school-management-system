{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(php artisan migrate)",
      "Bash(php artisan migrate:status)",
      "Bash(php artisan tenants:migrate)",
      "Bash(php artisan tenants:migrate-fresh)",
      "Bash(php artisan tenants:seed)",
      "Bash(php artisan tenancy:install)",
      "Bash(php artisan make:*)",
      "Bash(php artisan test*)",
      "Bash(php artisan db:seed*)",
      "Bash(./vendor/bin/pint*)",
      "Bash(composer require*)",
      "Bash(composer install)",
      "Bash(npm install*)",
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git add*)",
      "Bash(git commit*)"
    ],
    "ask": [
      "Bash(php artisan migrate:fresh*)",
      "Bash(php artisan tenants:migrate-fresh*)",
      "Bash(php artisan migrate:rollback*)",
      "Bash(git push*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Bash(php artisan migrate:fresh --force*)"
    ]
  },
  "env": {
    "APP_ENV": "local"
  }
}
