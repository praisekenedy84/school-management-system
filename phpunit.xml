<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="CACHE_STORE" value="array"/>
        <env name="DB_CONNECTION" value="pgsql"/>
        <env name="DB_HOST" value="localhost"/>
        <env name="DB_PORT" value="5433"/>
        <env name="DB_DATABASE" value="sms_testing"/>
        <env name="DB_USERNAME" value="postgres"/>
        <env name="DB_PASSWORD" value="root"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <!-- 'array' driver doesn't reliably persist real invalidate()/regenerate()
             semantics across separate simulated requests within one test
             (see tests/Feature/Auth/LoginTest.php) — use the same 'database'
             driver as dev/prod so logout genuinely invalidates the session. -->
        <env name="SESSION_DRIVER" value="database"/>
        <!-- ADR-0008: pin sessions to the literal central connection name so
             they're readable before any tenant is known, regardless of
             whatever the developer's own .env has — see
             app/Http/Middleware/InitializeTenancyFromSession.php. -->
        <env name="SESSION_CONNECTION" value="pgsql"/>
        <env name="SESSION_DOMAIN" value=""/>
        <env name="SANCTUM_STATEFUL_DOMAINS" value="localhost,127.0.0.1"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
    </php>
</phpunit>
